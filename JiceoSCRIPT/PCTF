local function saveOriginalProps(char)
    originalProps = {}
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            originalProps[part] = part.CustomPhysicalProperties
        end
    end
end

local function restoreOriginalProps(char)
    for part, props in pairs(originalProps) do
        if part and part.Parent and props then
            pcall(function() part.CustomPhysicalProperties = props end)
        end
    end
end

local function setupSpeedForce(enable)
    local char = player.Character
    if not char then return end
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end

    if vectorForce then vectorForce:Destroy() vectorForce = nil end

    if enable then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.1, 0.5, 0.5, 1)
            end
        end

        vectorForce = Instance.new("VectorForce")
        vectorForce.Force = Vector3.new(0, 0, 0)
        vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
        vectorForce.ApplyAtCenterOfMass = true
        local attachment = hrp:FindFirstChild("RootRigAttachment") or Instance.new("Attachment", hrp)
        vectorForce.Attachment0 = attachment
        vectorForce.Parent = hrp
    end
end

player.CharacterAdded:Connect(function(char)
    task.wait(1)
    saveOriginalProps(char)
    if flags.speedEnabled then setupSpeedForce(true) end
end)

if player.Character then saveOriginalProps(player.Character) end

--- FUNCTIONS ---

local function setCharacterFreeze(freeze)
    local char = player.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then 
                part.Anchored = freeze 
            end
        end
    end
end

local function instantTP(pos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local target = (typeof(pos) == "Vector3" and CFrame.new(pos)) or pos
        char.HumanoidRootPart.CFrame = target
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end
end

-- HÀM TELEPORT CÓ ĐÓNG BĂNG 5 GIÂY
local function tpWithFreeze(position, islandName)
    if not position then return end
    
    -- Thông báo
    Rayfield:Notify({
        Title = "Teleport", 
        Content = "Đang dịch chuyển đến " .. islandName .. "...", 
        Duration = 2
    })
    
    -- Teleport
    instantTP(position)
    task.wait(0.5)
    
    -- Đóng băng nhân vật
    setCharacterFreeze(true)
    
    -- Thông báo đóng băng
    Rayfield:Notify({
        Title = "⚠️ Đóng băng", 
        Content = "Nhân vật sẽ đóng băng trong 5 giây để tránh lag!", 
        Duration = 3
    })
    
    -- Chờ 5 giây
    task.wait(5)
    
    -- Mở đóng băng
    setCharacterFreeze(false)
    
    -- Thông báo hoàn tất
    Rayfield:Notify({
        Title = "✅ Hoàn tất", 
        Content = "Đã đến " .. islandName .. " và trở lại bình thường!", 
        Duration = 2
    })
end

local function fixLag()
    local lighting = game:GetService("Lighting")
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    settings().Rendering.QualityLevel = 1
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Part") or v:IsA("UnionOperation") or v:IsA("MeshPart") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") then
            v.Material = "Plastic"
            v.Reflectance = 0
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
            v.Enabled = false
        elseif v:IsA("Explosion") then
            v.Visible = false
        end
    end
    Rayfield:Notify({Title = "Fix Lag", Content = "Graphics Optimized!", Duration = 3})
end

local function forceClick(button)
    if not button then return end
    pcall(function()
        local pos = button.AbsolutePosition
        local size = button.AbsoluteSize
        local centerX = pos.X + size.X / 2
        local centerY = pos.Y + size.Y / 2 + 58
        vim:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
        task.wait(0.05)
        vim:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
    end)
end

local function performFastSell()
    if not farmPosition then return end
    _G.IsSelling = true
    timeRemaining = sellInterval
    instantTP(sellPosition)
    task.wait(0.5)
    setCharacterFreeze(true) 

    local sellGui = player.PlayerGui:FindFirstChild("SellGUI")
    local retry = 0
    while (not sellGui or not sellGui.Enabled) and retry < 12 do
        vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.1)
        vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.4)
        sellGui = player.PlayerGui:FindFirstChild("SellGUI")
        retry = retry + 1
    end

    if sellGui and sellGui.Enabled then
        local main = sellGui:FindFirstChild("Main")
        if main then
            if main:FindFirstChild("All") then forceClick(main.All) end
            task.wait(0.6)
            if main:FindFirstChild("Close") then forceClick(main.Close) end
        end
    end
    task.wait(2.5) 
    setCharacterFreeze(false)
    instantTP(farmPosition)
    _G.IsSelling = false
end

