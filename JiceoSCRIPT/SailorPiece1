-- Hàm tìm Boss sống
local function FindLivingBoss(bossID)
    local npcFolder = game.Workspace:FindFirstChild("NPCs")
    local boss = (npcFolder and npcFolder:FindFirstChild(bossID)) or game.Workspace:FindFirstChild(bossID, true)
    if boss and boss:FindFirstChild("Humanoid") and boss.Humanoid.Health > 0 then
        return boss
    end
    return nil
end

-- Hàm sử dụng tool theo vị trí
local function UseTool(toolPosition)
    local character = game.Players.LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Tìm tool trong backpack hoặc character
    local tool = nil
    local backpack = game.Players.LocalPlayer.Backpack
    
    -- Kiểm tra trong Backpack trước
    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            local toolName = string.lower(item.Name)
            if toolPosition == 1 and (toolName:find("1") or toolName:find("one") or toolName:find("slot1")) then
                tool = item
                break
            elseif toolPosition == 2 and (toolName:find("2") or toolName:find("two") or toolName:find("slot2")) then
                tool = item
                break
            elseif toolPosition == 3 and (toolName:find("3") or toolName:find("three") or toolName:find("slot3")) then
                tool = item
                break
            end
        end
    end
    
    -- Nếu không tìm thấy trong Backpack, kiểm tra trong Character
    if not tool then
        for _, item in pairs(character:GetChildren()) do
            if item:IsA("Tool") then
                local toolName = string.lower(item.Name)
                if toolPosition == 1 and (toolName:find("1") or toolName:find("one") or toolName:find("slot1")) then
                    tool = item
                    break
                elseif toolPosition == 2 and (toolName:find("2") or toolName:find("two") or toolName:find("slot2")) then
                    tool = item
                    break
                elseif toolPosition == 3 and (toolName:find("3") or toolName:find("three") or toolName:find("slot3")) then
                    tool = item
                    break
                end
            end
        end
    end
    
    -- Sử dụng tool nếu tìm thấy
    if tool then
        -- Đưa tool vào tay nếu chưa có
        if tool.Parent ~= character then
            tool.Parent = character
            task.wait(0.1)
        end
        
        -- Kích hoạt tool
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:EquipTool(tool)
            task.wait(0.1)
            
            -- Gửi yêu cầu sử dụng tool
            local toolRemote = game:GetService("ReplicatedStorage"):FindFirstChild("ToolSystem") or 
                              game:GetService("ReplicatedStorage"):FindFirstChild("Remotes"):FindFirstChild("UseTool")
            if toolRemote then
                toolRemote:FireServer(tool)
            end
            
            -- Thử activation nếu có
            if tool:FindFirstChild("Activate") then
                tool:Activate()
            end
        end
    end
end

-- Hàm ổn định & Ngả người
local function Stabilize(hrp)
    if not hrp:FindFirstChild("JiceoVelocity") then
        local bv = Instance.new("BodyVelocity", hrp)
        bv.Name = "JiceoVelocity"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = Vector3.new(0,0,0)
        
        local bg = Instance.new("BodyGyro", hrp)
        bg.Name = "JiceoGyro"
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.P = 30000
    end
end

