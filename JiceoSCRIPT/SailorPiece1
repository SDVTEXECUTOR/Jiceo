-- VÒNG LẶP ĐIỀU KHIỂN CHÍNH (Xử lý Ưu tiên + Ngả người + Loop Hit + Auto Tools)
spawn(function()
    local currentIsland = ""
    local lastToolUse = {0, 0, 0} -- Thời gian sử dụng tool lần cuối
    local toolCooldown = 2 -- Cooldown 2 giây giữa các lần sử dụng tool
    
    while true do
        task.wait()
        local character = game.Players.LocalPlayer.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local targetBoss = nil
        local targetConfig = nil

        -- Logic Ưu tiên: Duyệt theo thứ tự Order, tick cái nào cao hơn đánh trước
        for _, config in pairs(priorityList) do
            if _G.SelectedBosses[config.ID] then
                local boss = FindLivingBoss(config.ID)
                if boss then
                    targetBoss = boss
                    targetConfig = config
                    break 
                end
            end
        end

        if targetBoss and targetConfig then
            -- Chuyển đảo
            if currentIsland ~= targetConfig.Island then
                game:GetService("ReplicatedStorage").Remotes.TeleportToPortal:FireServer(targetConfig.Island)
                task.wait(2)
                currentIsland = targetConfig.Island
                if targetConfig.ID == "GojoBoss" then
                    hrp.CFrame = CFrame.new(1858.32, 32.98, 338.14)
                    task.wait(1)
                end
            end

            -- Tấn công & Ngả người
            local targetHrp = targetBoss:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                Stabilize(hrp)
                -- Ngả người 90 độ xuống Boss
                local targetPos = targetHrp.CFrame * CFrame.new(0, 12, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                local dist = (hrp.Position - targetPos.Position).Magnitude

                if dist > 15 then
                    TweenService:Create(hrp, TweenInfo.new(dist/_G.TweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetPos}):Play()
                else
                    hrp.CFrame = targetPos
                    -- Loop Skill liên tục
                    local skillRemote = game:GetService("ReplicatedStorage").AbilitySystem.Remotes.RequestAbility
                    if _G.AutoSkills.Z then skillRemote:FireServer(1) end
                    if _G.AutoSkills.X then skillRemote:FireServer(2) end
                    if _G.AutoSkills.C then skillRemote:FireServer(3) end
                    if _G.AutoSkills.V then skillRemote:FireServer(4) end
                    if _G.AutoSkills.F then skillRemote:FireServer(5) end
                    
                    -- Auto sử dụng tools
                    local currentTime = tick()
                    
                    -- Tool 1
                    if _G.AutoTools.Tool1 and (currentTime - lastToolUse[1]) >= toolCooldown then
                        UseTool(1)
                        lastToolUse[1] = currentTime
                    end
                    
                    -- Tool 2
                    if _G.AutoTools.Tool2 and (currentTime - lastToolUse[2]) >= toolCooldown then
                        UseTool(2)
                        lastToolUse[2] = currentTime
                    end
                    
                    -- Tool 3
                    if _G.AutoTools.Tool3 and (currentTime - lastToolUse[3]) >= toolCooldown then
                        UseTool(3)
                        lastToolUse[3] = currentTime
                    end
                end
                -- Loop Chém liên tục
                game:GetService("ReplicatedStorage").CombatSystem.Remotes.RequestHit:FireServer()
            end
        else
            -- Dọn dẹp lực khi không đánh Boss
            if hrp:FindFirstChild("JiceoVelocity") then hrp.JiceoVelocity:Destroy() end
            if hrp:FindFirstChild("JiceoGyro") then hrp.JiceoGyro:Destroy() end
            currentIsland = ""
        end
    end
end)

