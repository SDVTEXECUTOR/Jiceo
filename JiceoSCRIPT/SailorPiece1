-- Vòng lặp cập nhật Timer liên tục
spawn(function()
    while true do
        for _, config in pairs(priorityList) do
            local boss = FindLivingBoss(config.ID)
            if boss then
                statusLabels[config.ID]:Set(config.Name .. ": 🟢 ALIVE")
            else
                -- CODE LẤY TIME REAL ĐÂY: Quét đúng Container trong Workspace
                local container = game.Workspace:FindFirstChild("TimedBossSpawn_" .. config.ID .. "_Container", true)
                local timeStr = "N/A"
                if container then
                    local mainObj = container:FindFirstChild("TimedBossSpawn_" .. config.ID)
                    local timerPart = mainObj and mainObj:FindFirstChild("Timer", true)
                    if timerPart and timerPart:IsA("TextLabel") then
                        timeStr = timerPart.Text
                    elseif timerPart and timerPart:IsA("SurfaceGui") then
                        local lbl = timerPart:FindFirstChildWhichIsA("TextLabel", true)
                        if lbl then timeStr = lbl.Text end
                    end
                end
                statusLabels[config.ID]:Set(config.Name .. ": 🔴 Respawning: " .. timeStr)
            end
        end
        task.wait(1)
    end
end)

