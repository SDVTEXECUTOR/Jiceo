-- ==================== HÀM HỖ TRỢ ====================
local function saveOriginalProps(char)
    originalProps = {}
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            originalProps[part] = part.CustomPhysicalProperties
        end
    end
end

local function restoreOriginalProps(char)
    for part, props in pairs(originalProps) do
        if part and part.Parent and props then
            pcall(function() part.CustomPhysicalProperties = props end)
        end
    end
end

local function setupSpeedForce(enable)
    local char = plr.Character
    if not char then return end
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end
    
    if vectorForce then vectorForce:Destroy() vectorForce = nil end
    
    if enable then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.1, 0.5, 0.5, 1)
            end
        end
        vectorForce = Instance.new("VectorForce")
        vectorForce.Force = Vector3.new(0, 0, 0)
        vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
        vectorForce.ApplyAtCenterOfMass = true
        local attachment = hrp:FindFirstChild("RootRigAttachment") or Instance.new("Attachment", hrp)
        vectorForce.Attachment0 = attachment
        vectorForce.Parent = hrp
    end
end

local function FireButtonSafe(button)
    if not button or not button:IsA("GuiButton") or not button.Visible then return end
   
    pcall(function()
        for _, conn in pairs(getconnections(button.MouseButton1Click)) do conn:Fire() end
        for _, conn in pairs(getconnections(button.Activated)) do conn:Fire() end
    end)
   
    local x = button.AbsolutePosition.X + button.AbsoluteSize.X / 2
    local y = button.AbsolutePosition.Y + button.AbsoluteSize.Y / 2 + 55
   
    vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.035)
    vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

local function GetDistanceToFarm()
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not getgenv().SavedFarmPos then return 999 end
    return (hrp.Position - getgenv().SavedFarmPos).Magnitude
end

local function instantTP(pos)
    local char = plr.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local target = (typeof(pos) == "Vector3" and CFrame.new(pos)) or pos
        char.HumanoidRootPart.CFrame = target
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end
end

local function setCharacterFreeze(freeze)
    local char = plr.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = freeze
        end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = freeze
            end
        end
    end
end

local function tpWithFreeze(position, islandName)
    if not position then return end
   
    Rayfield:Notify({Title = "Teleport", Content = "Đang dịch chuyển đến " .. islandName .. "...", Duration = 2})
   
    instantTP(position)
    task.wait(0.08)
   
    setCharacterFreeze(true)
   
    Rayfield:Notify({Title = "🧊 Đóng băng ngay lập tức", Content = "Nhân vật frozen 5 giây để chống kick/anti-TP", Duration = 4})
   
    task.wait(5)
   
    setCharacterFreeze(false)
   
    Rayfield:Notify({Title = "✅ Đến nơi", Content = "Đã đến " .. islandName .. " thành công!", Duration = 2})
end

local function fixLag()
    local lighting = game:GetService("Lighting")
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    settings().Rendering.QualityLevel = 1
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Part") or v:IsA("UnionOperation") or v:IsA("MeshPart") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") then
            v.Material = "Plastic"
            v.Reflectance = 0
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
            v.Enabled = false
        elseif v:IsA("Explosion") then
            v.Visible = false
        end
    end
    Rayfield:Notify({Title = "Fix Lag", Content = "Graphics Optimized!", Duration = 3})
end

